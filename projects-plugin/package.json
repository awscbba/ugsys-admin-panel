    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nanostores/react": "^0.8.0",
    "@ugsys/ui-lib": "github:awscbba/ugsys-ui-lib#v0.1.7",
