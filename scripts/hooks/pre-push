#!/usr/bin/env bash
# pre-push hook: block direct push to main, run full type-check + test suite with 80% coverage gate

set -euo pipefail

BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || echo "")

echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  pre-push checks"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

if [ "$BRANCH" = "main" ]; then
    echo "✗ Direct pushes to 'main' are not allowed."
    echo "  Please open a pull request instead."
    exit 1
fi

echo "  branch : $BRANCH"
echo ""

FAILED=0

echo "── BFF (Python) ─────────────────────────────────────"
echo ""

echo "▶ mypy --strict ..."
if ! just type-check; then
    echo "✗ mypy failed. Run 'just type-check' for details."
    FAILED=1
else
    echo "✓ mypy passed"
fi
echo ""

echo "▶ pytest --cov=src --cov-fail-under=80 ..."
if ! just test-coverage; then
    echo "✗ Tests failed or coverage below 80%. Run 'just test-coverage' for details."
    FAILED=1
else
    echo "✓ pytest passed (≥80% coverage)"
fi
echo ""

echo "── Admin Shell (TypeScript) ─────────────────────────"
echo ""

echo "▶ tsc --noEmit ..."
if ! just type-check-frontend; then
    echo "✗ TypeScript type check failed. Run 'just type-check-frontend' for details."
    FAILED=1
else
    echo "✓ tsc passed"
fi
echo ""

echo "▶ vitest run --coverage ..."
if ! just test-coverage-frontend; then
    echo "✗ Frontend tests failed or coverage below 80%. Run 'just test-coverage-frontend' for details."
    FAILED=1
else
    echo "✓ vitest passed (≥80% coverage)"
fi
echo ""

echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
if [ "$FAILED" -ne 0 ]; then
    echo "✗ pre-push checks FAILED — fix the errors above before pushing."
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    exit 1
fi

echo "✓ pre-push checks passed"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
exit 0
