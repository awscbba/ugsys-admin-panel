#!/usr/bin/env bash
# pre-commit hook: block direct commits to main, lint staged files

set -euo pipefail

BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || echo "")

if [ "$BRANCH" = "main" ]; then
    echo "ERROR: Direct commits to 'main' are not allowed."
    echo "       Please create a feature branch and open a pull request."
    exit 1
fi

REPO_ROOT=$(git rev-parse --show-toplevel)
cd "$REPO_ROOT/ugsys-admin-panel"

# --- Python: ruff on staged .py files ---
STAGED_PY=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' || true)

if [ -n "$STAGED_PY" ]; then
    echo "Running ruff check on staged Python files..."
    # shellcheck disable=SC2086
    if ! uv run ruff check $STAGED_PY; then
        echo "ERROR: ruff check failed. Run 'just lint' to see all issues."
        exit 1
    fi

    echo "Running ruff format --check on staged Python files..."
    # shellcheck disable=SC2086
    if ! uv run ruff format --check $STAGED_PY; then
        echo "ERROR: ruff format check failed. Run 'just format' to fix."
        exit 1
    fi
fi

# --- TypeScript/React: ESLint + Prettier on staged .ts/.tsx files ---
STAGED_TS=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx)$' || true)

if [ -n "$STAGED_TS" ]; then
    echo "Running ESLint on staged TypeScript/React files..."
    # shellcheck disable=SC2086
    if ! npx eslint --max-warnings=0 $STAGED_TS; then
        echo "ERROR: ESLint failed. Run 'just lint-frontend' to see all issues."
        exit 1
    fi

    echo "Running Prettier check on staged TypeScript/React files..."
    # shellcheck disable=SC2086
    if ! npx prettier --check $STAGED_TS; then
        echo "ERROR: Prettier check failed. Run 'just format-frontend' to fix."
        exit 1
    fi
fi

echo "pre-commit checks passed."
exit 0
